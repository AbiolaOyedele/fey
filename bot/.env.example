# Twilio — https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio WhatsApp sandbox number (without "whatsapp:" prefix), e.g. +14155238886
TWILIO_WHATSAPP_NUMBER=

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Supabase — use the SERVICE ROLE key (not the anon key) so the bot bypasses RLS
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Port (Railway sets this automatically; only needed for local dev)
PORT=3001
